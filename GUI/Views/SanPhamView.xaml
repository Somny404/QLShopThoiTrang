<UserControl x:Class="GUI.Views.SanPhamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}" Loaded="UserControl_Loaded">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📦 Quản lý sản phẩm" Style="{StaticResource HeaderLabel}"/>

        <!-- Form nhập liệu -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Grid.Row="0" Margin="4">
                    <TextBlock Text="Mã SP" FontSize="12" Foreground="#666"/>
                    <TextBox x:Name="txtMaSP" Style="{StaticResource ModernTextBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Grid.Row="0" Margin="4">
                    <TextBlock Text="Tên SP" FontSize="12" Foreground="#666"/>
                    <TextBox x:Name="txtTenSP" Style="{StaticResource ModernTextBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Grid.Row="0" Margin="4">
                    <TextBlock Text="Giá bán" FontSize="12" Foreground="#666"/>
                    <TextBox x:Name="txtGiaBan" Style="{StaticResource ModernTextBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Grid.Row="0" Margin="4">
                    <TextBlock Text="Số lượng tồn" FontSize="12" Foreground="#666"/>
                    <TextBox x:Name="txtSoLuongTon" Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.Row="1" Margin="4">
                    <TextBlock Text="Size" FontSize="12" Foreground="#666"/>
                    <TextBox x:Name="txtSize" Style="{StaticResource ModernTextBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Grid.Row="1" Margin="4">
                    <TextBlock Text="Màu sắc" FontSize="12" Foreground="#666"/>
                    <TextBox x:Name="txtMauSac" Style="{StaticResource ModernTextBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Grid.Row="1" Margin="4">
                    <TextBlock Text="Loại SP" FontSize="12" Foreground="#666"/>
                    <ComboBox x:Name="cboLoai" DisplayMemberPath="TenLoai" SelectedValuePath="MaLoai"
                              FontSize="14" Padding="8,6" Margin="0,4"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Grid.Row="1" Margin="4">
                    <TextBlock Text="Tìm kiếm" FontSize="12" Foreground="#666"/>
                    <TextBox x:Name="txtTimKiem" Style="{StaticResource ModernTextBox}"
                             TextChanged="TxtTimKiem_TextChanged"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="2" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="4,8,0,0">
                    <Button Content="➕ Thêm" Style="{StaticResource BtnPrimary}" Click="BtnThem_Click"/>
                    <Button Content="✏️ Sửa" Style="{StaticResource BtnAccent}" Click="BtnSua_Click"/>
                    <Button Content="🗑️ Xóa" Style="{StaticResource BtnDanger}" Click="BtnXoa_Click" x:Name="btnXoa"/>
                    <Button Content="🔄 Làm mới" Style="{StaticResource BtnSuccess}" Click="BtnLamMoi_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" x:Name="dgSanPham" SelectionChanged="DgSanPham_SelectionChanged"
                  AutoGenerateColumns="True"/>
    </Grid>
</UserControl>
