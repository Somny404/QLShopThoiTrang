<UserControl x:Class="GUI.Views.HoaDonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}" Loaded="UserControl_Loaded">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Danh sách sản phẩm -->
        <StackPanel Grid.Column="0" Margin="0,0,16,0">
            <TextBlock Text="🛒 Bán hàng" Style="{StaticResource HeaderLabel}"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Tìm sản phẩm:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="txtTimSP" Width="300" Style="{StaticResource ModernTextBox}"
                         TextChanged="TxtTimSP_TextChanged"/>
            </StackPanel>

            <DataGrid x:Name="dgSanPham" Height="250" AutoGenerateColumns="True"/>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="Số lượng:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="txtSoLuong" Width="80" Style="{StaticResource ModernTextBox}" Text="1"/>
                <Button Content="➕ Thêm vào đơn" Style="{StaticResource BtnPrimary}" Click="BtnThemVaoDon_Click" Margin="8,0,0,0"/>
                <Button Content="❌ Xóa khỏi đơn" Style="{StaticResource BtnDanger}" Click="BtnXoaKhoiDon_Click" Margin="4,0,0,0"/>
            </StackPanel>

            <!-- Giỏ hàng hiện tại -->
            <TextBlock Text="📋 Chi tiết đơn hàng" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,8"/>
            <DataGrid x:Name="dgGioHang" Height="200" AutoGenerateColumns="True"/>
        </StackPanel>

        <!-- RIGHT: Thông tin hóa đơn -->
        <Border Grid.Column="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="📝 Thông tin hóa đơn" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                <TextBlock Text="Mã hóa đơn" FontSize="12" Foreground="#666"/>
                <TextBox x:Name="txtMaHD" Style="{StaticResource ModernTextBox}"/>

                <TextBlock Text="Khách hàng" FontSize="12" Foreground="#666" Margin="0,8,0,0"/>
                <ComboBox x:Name="cboKhachHang" DisplayMemberPath="TenKH" SelectedValuePath="MaKH"
                          FontSize="14" Padding="8,6" Margin="0,4"/>

                <Border Height="1" Background="#E0E0E0" Margin="0,16"/>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Tổng tiền:" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblTongTien" Text="0 VNĐ" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource DangerBrush}" Margin="8,0,0,0"/>
                </StackPanel>

                <Button Content="✅ THANH TOÁN" Style="{StaticResource BtnSuccess}"
                        FontSize="18" Height="50" Margin="0,20,0,0" Click="BtnThanhToan_Click"/>

                <Button Content="🔄 Đơn mới" Style="{StaticResource BtnPrimary}"
                        Margin="0,8,0,0" Click="BtnDonMoi_Click"/>

                <Border Height="1" Background="#E0E0E0" Margin="0,16"/>

                <!-- Lịch sử hóa đơn -->
                <TextBlock Text="📜 Hóa đơn gần đây" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <DataGrid x:Name="dgLichSu" Height="150" AutoGenerateColumns="True" FontSize="11"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
