<UserControl x:Class="GUI.Views.BackupRestoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <StackPanel Margin="24" MaxWidth="600" HorizontalAlignment="Left">
        <TextBlock Text="💾 Backup / Restore Database" Style="{StaticResource HeaderLabel}"/>

        <!-- Backup -->
        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="📤 Backup Database" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <TextBlock Text="Sao lưu toàn bộ database ra file .bak" Foreground="#666" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="txtBackupPath" Style="{StaticResource ModernTextBox}" Width="350"/>
                    <Button Content="📁 Chọn" Style="{StaticResource BtnPrimary}" Margin="8,0,0,0"
                            Click="BtnChonBackup_Click"/>
                </StackPanel>
                <Button Content="⬆ BACKUP" Style="{StaticResource BtnSuccess}"
                        Margin="0,12,0,0" Click="BtnBackup_Click" FontSize="16" Height="45"/>
            </StackPanel>
        </Border>

        <!-- Restore -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="📥 Restore Database" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <TextBlock Text="Khôi phục database từ file backup .bak" Foreground="#666" Margin="0,0,0,12"/>
                <TextBlock Text="⚠ LƯU Ý: Thao tác này sẽ ghi đè toàn bộ dữ liệu hiện tại!"
                           Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="txtRestorePath" Style="{StaticResource ModernTextBox}" Width="350"/>
                    <Button Content="📁 Chọn" Style="{StaticResource BtnPrimary}" Margin="8,0,0,0"
                            Click="BtnChonRestore_Click"/>
                </StackPanel>
                <Button Content="⬇ RESTORE" Style="{StaticResource BtnDanger}"
                        Margin="0,12,0,0" Click="BtnRestore_Click" FontSize="16" Height="45"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
