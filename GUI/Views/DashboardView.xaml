<UserControl x:Class="GUI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}" Loaded="UserControl_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="📊 Dashboard" Style="{StaticResource HeaderLabel}"/>

            <!-- Stats Cards -->
            <WrapPanel>
                <Border Style="{StaticResource Card}" Width="220">
                    <StackPanel>
                        <TextBlock Text="📦 Tổng sản phẩm" Style="{StaticResource SubHeaderLabel}"/>
                        <TextBlock x:Name="lblTongSP" Text="0" FontSize="32" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Width="220">
                    <StackPanel>
                        <TextBlock Text="👤 Tổng khách hàng" Style="{StaticResource SubHeaderLabel}"/>
                        <TextBlock x:Name="lblTongKH" Text="0" FontSize="32" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Width="220">
                    <StackPanel>
                        <TextBlock Text="🧾 Hóa đơn hôm nay" Style="{StaticResource SubHeaderLabel}"/>
                        <TextBlock x:Name="lblHDHomNay" Text="0" FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Width="220">
                    <StackPanel>
                        <TextBlock Text="⚠ SP sắp hết hàng" Style="{StaticResource SubHeaderLabel}"/>
                        <TextBlock x:Name="lblSPSapHet" Text="0" FontSize="32" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Top sản phẩm bán chạy -->
            <TextBlock Text="🏆 Top 5 sản phẩm bán chạy" FontSize="16" FontWeight="SemiBold" Margin="8,24,0,8"/>
            <Border Style="{StaticResource Card}" Padding="0">
                <DataGrid x:Name="dgTopSP" Height="180" AutoGenerateColumns="True"/>
            </Border>

            <!-- Sản phẩm sắp hết -->
            <TextBlock Text="⚠ Sản phẩm sắp hết hàng (tồn ≤ 10)" FontSize="16" FontWeight="SemiBold" Margin="8,16,0,8"/>
            <Border Style="{StaticResource Card}" Padding="0">
                <DataGrid x:Name="dgSPSapHet" Height="180" AutoGenerateColumns="True"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
