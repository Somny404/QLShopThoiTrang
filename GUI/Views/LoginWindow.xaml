<Window x:Class="GUI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập - QL Shop Thời Trang" Height="560" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F0F4F8">

    <Grid>
        <Border Style="{StaticResource Card}" VerticalAlignment="Center" HorizontalAlignment="Center"
                Width="320" Padding="30">
            <StackPanel>
                <!-- Logo / Title -->
                <TextBlock Text="👗" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="SHOP THỜI TRANG" FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="Đăng nhập hệ thống" FontSize="12" Foreground="#999"
                           HorizontalAlignment="Center" Margin="0,4,0,24"/>

                <!-- Username -->
                <TextBlock Text="Tên đăng nhập" FontSize="13" Foreground="#555" Margin="0,0,0,4"/>
                <TextBox x:Name="txtTenDN" Style="{StaticResource ModernTextBox}"/>

                <!-- Password -->
                <TextBlock Text="Mật khẩu" FontSize="13" Foreground="#555" Margin="0,12,0,4"/>
                <PasswordBox x:Name="txtMatKhau" FontSize="14" Padding="10,8" Margin="0,4"
                             BorderBrush="#CCC" BorderThickness="1"/>

                <!-- Error message -->
                <TextBlock x:Name="lblError" Foreground="{StaticResource DangerBrush}" FontSize="12"
                           Margin="0,8,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>

                <!-- Login button -->
                <Button Content="ĐĂNG NHẬP" Style="{StaticResource BtnPrimary}"
                        Margin="0,20,0,0" Click="BtnLogin_Click" Height="40"
                        HorizontalAlignment="Stretch"/>

                <!-- Footer -->
                <TextBlock Text="Nhóm 8 - Hệ QTCSDL" FontSize="11" Foreground="#AAA"
                           HorizontalAlignment="Center" Margin="0,16,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
